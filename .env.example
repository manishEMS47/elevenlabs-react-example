# Copy this file to `.env.local` (git-ignored) and fill in your keys.
# Only VITE_-prefixed vars are exposed to the browser by Vite.
#
# WARNING: these keys are bundled into client-side code. Fine for a local demo,
# but use a backend proxy in production so keys never reach the browser.

VITE_ELEVENLABS_API_KEY=your_elevenlabs_key_here
VITE_60DB_API_KEY=your_60db_key_here
